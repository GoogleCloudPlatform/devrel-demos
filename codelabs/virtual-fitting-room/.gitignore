# === Un-ignore patterns the repo-root .gitignore would otherwise hide ===
# Repo root has 'lib/' (for Python packaging) and 'tmp' (for builds),
# which would filter out this Flutter app's source and the Windows runner.
!flutter_frontend/lib/
!flutter_frontend/lib/**
!flutter_frontend/windows/runner/
!flutter_frontend/windows/runner/**

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment / secrets — never commit these
.env
**/.env
agents/.env
backend/.env
adk_backend/.env

# Flutter build copied into the backend for Cloud Run packaging
adk_backend/flutter_web/

# Internal design notes (kept local, not for public repo)
adk_backend/docs/auth-and-retries.md
adk_backend/docs/identity-preservation.md

# IDE configs
.claude/

# Go agent scratch/debug files
agents/test_output.json
agents/test_payload.py
agents/backend.log
