# ==============================================================================
# Hackathon Judge Configuration Template
# ==============================================================================

# ------------------------------------------------------------------------------
# Google Cloud Platform Core Configuration
# ------------------------------------------------------------------------------
# The Google Cloud active project ID.
GOOGLE_CLOUD_PROJECT=

# Target deployment region for all resources.
GOOGLE_CLOUD_REGION=

# Location for the Artifact Registry docker repository.
ARTIFACT_REGISTRY_LOCATION=us

# ------------------------------------------------------------------------------
# Infrastructure Names
# ------------------------------------------------------------------------------
# Name of the GKE Autopilot cluster.
CLUSTER_NAME=hackathon-judge-cluster

# Name of the Artifact Registry repository.
ARTIFACT_REPO_NAME=hackathon-judge-repo

# ------------------------------------------------------------------------------
# Pub/Sub Messaging Architecture
# ------------------------------------------------------------------------------
# Pub/Sub topic where new judging tasks are published.
TASKS_TOPIC=judging-tasks

# Pub/Sub topic where judging evaluation results are published.
RESULTS_TOPIC=judging-results

# Pub/Sub subscription used by the Agent to listen for judging tasks.
TASKS_SUBSCRIPTION=judging-tasks-agent-sub

# Pub/Sub subscription used by the Backend to listen for judging results.
RESULTS_SUB=judging-results-backend-sub

# ------------------------------------------------------------------------------
# BigQuery Analytics Setup
# ------------------------------------------------------------------------------
# Name of the BigQuery Dataset (created in target GCP region).
BQ_DATASET=hackathon_judge

